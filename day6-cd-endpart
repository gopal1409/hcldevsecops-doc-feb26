  #modify the ci.yml file from the skyproject
  name: Enterprise DevSecOps Pipeline

on:
  push:
    branches: [main]

permissions:
  contents: write
  security-events: write
  actions: read
  id-token: write

env:
  FRONTEND_IMAGE: ${{ secrets.DOCKER_USERNAME }}/frontend
  BACKEND_IMAGE: ${{ secrets.DOCKER_USERNAME }}/backend

jobs:

# -----------------------------
# Build Frontend
# -----------------------------

  frontend-build:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4

    - uses: actions/setup-node@v4
      with:
        node-version: 20

    - name: Fix npm optional dependency bug
      run: |
        cd frontend
        rm -rf node_modules
        rm -f package-lock.json
        npm install

    - name: Build React
      run: |
        cd frontend
        npm run build
# -----------------------------
# Build Backend
# -----------------------------

  backend-build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Build Spring Boot
        run: |
          cd backend
          mvn clean package


# -----------------------------
# Docker Build + Scan
# -----------------------------

  docker-build-scan:
    runs-on: ubuntu-latest
    needs: [frontend-build, backend-build]

    steps:
      - uses: actions/checkout@v4

      # Build Images
      - name: Build Frontend Image
        run: docker build -t frontend-image ./frontend

      - name: Build Backend Image
        run: docker build -t backend-image ./backend

      # Install Trivy
      - uses: aquasecurity/setup-trivy@v0.2.0

      # Scan Images
      - name: Scan Frontend Image
        run: |
          trivy image --severity CRITICAL,HIGH,MEDIUM,LOW \
          --format sarif -o trivy-results.sarif frontend-image

      - name: Scan Backend Image
        run: |
          trivy image --severity CRITICAL,HIGH,MEDIUM,LOW \
          --format sarif -o trivy-results.sarif backend-image

      - name: Upload Trivy SARIF
        uses: github/codeql-action/upload-sarif@v4
        with:
          sarif_file: trivy-results.sarif

      # Docker login
      - name: Docker Login
        run: |
          echo "${{ secrets.DOCKER_PASSWORD }}" | docker login \
          -u ${{ secrets.DOCKER_USERNAME }} --password-stdin

      # Tag images
      - name: Tag Images
        run: |
          docker tag backend-image $BACKEND_IMAGE:${{ github.sha }}
          docker tag frontend-image $FRONTEND_IMAGE:${{ github.sha }}

      # Push images
      - name: Push Images
        run: |
          docker push $BACKEND_IMAGE:${{ github.sha }}
          docker push $FRONTEND_IMAGE:${{ github.sha }}


# -----------------------------
# Run Containers
# -----------------------------

  run-container:
    runs-on: ubuntu-latest
    needs: docker-build-scan

    steps:

      - name: Docker Login
        run: |
          echo "${{ secrets.DOCKER_PASSWORD }}" | docker login \
          -u ${{ secrets.DOCKER_USERNAME }} --password-stdin

      - name: Pull Images
        run: |
          docker pull $BACKEND_IMAGE:${{ github.sha }}
          docker pull $FRONTEND_IMAGE:${{ github.sha }}

      - name: Run Backend
        run: |
          docker run -d -p 8080:8080 $BACKEND_IMAGE:${{ github.sha }}
          sleep 20

      - name: Run Frontend
        run: |
          docker run -d -p 3000:80 $FRONTEND_IMAGE:${{ github.sha }}


# -----------------------------
# DAST Scan
# -----------------------------

  dast-test:
    runs-on: ubuntu-latest
    needs: run-container
    steps:

      - name: Checkout code
        uses: actions/checkout@v4

      # Build containers
      - name: Build containers
        run: docker compose build

      # Start services
      - name: Start application stack
        run: docker compose up -d

      # Wait until backend is ready
      - name: Wait for backend
        run: |
          for i in {1..30}; do
            if curl -s http://localhost:8080 > /dev/null; then
              echo "Backend ready"
              exit 0
            fi
            echo "Waiting for backend..."
            sleep 5
          done
          echo "Backend failed to start"
          docker compose logs backend
          exit 1

# -----------------------------
# Image Signing
# -----------------------------

  image-sign:
    runs-on: ubuntu-latest
    needs: dast-test

    permissions:
      id-token: write
      contents: read

    steps:

      - uses: sigstore/cosign-installer@v3

      - name: Login DockerHub
        run: |
          echo "${{ secrets.DOCKER_PASSWORD }}" | docker login \
          -u ${{ secrets.DOCKER_USERNAME }} --password-stdin

      - name: Sign Backend Image
        run: |
          cosign sign --yes $BACKEND_IMAGE:${{ github.sha }}

      - name: Sign Frontend Image
        run: |
          cosign sign --yes $FRONTEND_IMAGE:${{ github.sha }}


# -----------------------------
# Update GitOps Repository
# -----------------------------

  update-gitops:
    runs-on: ubuntu-latest
    needs: docker-build-scan

    steps:

      - name: Checkout GitOps Repo
        uses: actions/checkout@v4
        with:
          #change the repo name to your gitops repo
          repository: gopal1409/hcl-dev-secops-manifest-feb26-gitops
          token: ${{ secrets.GITOPS_TOKEN }}

      

      - name: Commit and Push
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add base/backend-deployment.yaml
          git add base/frontend-deployment.yaml

          git diff --cached --quiet || git commit -m "Update image tag to ${{ github.sha }}"
          git push
