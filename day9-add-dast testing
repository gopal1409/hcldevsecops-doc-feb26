##better you can copy your pipeline in a note pad then modify the pipeline with your application id which is unique to you
trigger:
- master

pool:
  name: default

variables:

  imageName: springboot-dast
  tag: $(Build.BuildId)

stages:

#################################
# BUILD STAGE
#################################

- stage: Build
  displayName: Secure Build Stage

  jobs:

#################################
# BUILD JOB
#################################

  - job: MavenBuild
    displayName: Secure Maven Build

    steps:

#################################
# SOURCE CONTROL CHECK
#################################

    - checkout: self
      persistCredentials: true

#################################
# SECRET SCAN
#################################

    - script: |
        docker run --rm \
        -v $(System.DefaultWorkingDirectory):/path \
        zricethezav/gitleaks detect \
        --source="/path" \
        --report-format=json \
        --report-path=/path/gitleaks-report.json
      displayName: Secret Scan

#################################
# MAVEN BUILD
#################################

    - task: Maven@4

      displayName: Maven Build

      inputs:

        mavenPomFile: pom.xml
        goals: clean install
        publishJUnitResults: true
        testResultsFiles: '**/surefire-reports/TEST-*.xml'

#################################
# SAST
#################################

    - task: HCLAppScanOnCloud@2

      inputs:

        AppSecTestService: hclappscan
        applications: ca72e53b-5bd3-4626-ba24-8d4106cf31c2
        scantype: static
        scanMethod: IRXless

      continueOnError: true

#################################
# DAST JOB (PARALLEL)
#################################

  - job: DAST
    displayName: Dynamic Security Testing

    dependsOn: MavenBuild

    steps:

#################################
# DOCKER BUILD
#################################

    - task: Docker@2

      displayName: Docker Build

      inputs:

        command: build
        Dockerfile: dockerfile
        repository: $(imageName)
        tags: |
          $(tag)

#################################
# RUN CONTAINER
#################################

    - script: |

        docker run -d \
        -p 8080:8080 \
        --name springboot-test \
        $(imageName):$(tag)

        sleep 60

      displayName: Run container

#################################
# DAST SCAN
#################################

    - task: HCLAppScanOnCloud@2

      displayName: DAST Scan

      inputs:

        AppSecTestService: hclappscan
        applications: ca72e53b-5bd3-4626-ba24-8d4106cf31c2 
        scantype: dynamic
        dynamicType: DAST
        scanURL: http://localhost:8080
        network: public

      continueOnError: true

#################################
# CLEANUP
#################################

    - script: |

        docker stop springboot-test

        docker rm springboot-test

      displayName: Cleanup
      condition: always()
