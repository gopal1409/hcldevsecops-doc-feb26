##lets move to the main branch
  git checkout main 
  ##lets create a new branch skynet
  git checkout -b skynet
  ####inside the branch we will create a folder .github #inside that create another folder called as workflows inside this create a file called as ci.yml
  ####lets create the github action project inside ci.yml add this stage
  name: Enterprise DevSecOps Pipeline

on:
  push:
    branches: [main, skynet]

permissions:
  contents: write
  security-events: write
  actions: read
  id-token: write

env:
  FRONTEND_IMAGE: ${{ secrets.DOCKER_USERNAME }}/frontend
  BACKEND_IMAGE: ${{ secrets.DOCKER_USERNAME }}/backend

jobs:

# -----------------------------
# Build Frontend
# -----------------------------

  frontend-build:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4

    - uses: actions/setup-node@v4
      with:
        node-version: 20

    - name: Fix npm optional dependency bug
      run: |
        cd frontend
        rm -rf node_modules
        rm -f package-lock.json
        npm install

    - name: Build React
      run: |
        cd frontend
        npm run build
# -----------------------------
# Build Backend
# -----------------------------

  backend-build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Build Spring Boot
        run: |
          cd backend
          mvn clean package

##once created 
          git add .
          git commit -m "skynet started"
          git push origin skynet
  
