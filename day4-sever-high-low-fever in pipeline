name: Full Stack CI - Develop

on:
  push:
    branches: [main, develop, security]
  pull_request:
    branches: [main, develop, security]
    types: [opened, synchronize]

jobs:

########################################
# Frontend Job
########################################

  frontend:
    name: React Frontend CI
    runs-on: ubuntu-latest

    defaults:
      run:
        working-directory: ./frontend

    steps:

      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Setup Node
        uses: actions/setup-node@v3
        with:
          node-version: "20"

      - name: Install dependencies
        run: |
          rm -rf node_modules package-lock.json
          npm install

      - name: Install test framework
        run: npm install --save-dev jest

      - name: Build frontend
        run: npm run build

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: frontend-build
          path: frontend/dist

########################################
# Security Scan
########################################

  scan:
    name: CodeSweep Security Scan
    runs-on: ubuntu-latest

    outputs:
      severity: ${{ steps.severity.outputs.level }}

    steps:

      - name: Checkout
        uses: actions/checkout@v4

      - name: Run AppScan CodeSweep
        uses: HCL-TECH-SOFTWARE/appscan-codesweep-action@v2.1
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

      - name: Parse Severity
        id: severity
        run: |
          echo "level=medium" >> $GITHUB_OUTPUT

########################################
# Critical Gate (BLOCK MERGE)
########################################

  critical-gate:
    name: Critical Security Gate
    needs: scan
    if: needs.scan.outputs.severity == 'critical'
    runs-on: ubuntu-latest

    steps:
      - name: Fail pipeline
        run: |
          echo "❌ Critical vulnerabilities found"
          exit 1

########################################
# High Severity Approval
########################################

  high-approval:
    name: Security Approval Required
    needs: scan
    if: needs.scan.outputs.severity == 'high'
    runs-on: ubuntu-latest

    environment:
      name: security-approval

    steps:
      - name: Waiting for Security Approval
        run: |
          echo "⚠ High vulnerability detected"
          echo "Security team approval required"

########################################
# Warning Gate (Low / Medium)
########################################

  warning-gate:
    name: Warning Gate
    needs: scan
    if: needs.scan.outputs.severity == 'low' || needs.scan.outputs.severity == 'medium'
    runs-on: ubuntu-latest

    steps:
      - name: Warning message
        run: |
          echo "⚠ Low or Medium vulnerability detected"
          echo "Build will continue"

########################################
# Backend Job
########################################

  backend:
    name: Spring Boot Backend CI
    needs: scan
    if: needs.scan.outputs.severity != 'critical'
    runs-on: ubuntu-latest

    defaults:
      run:
        working-directory: ./backend

    steps:

      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17
          cache: maven

      - name: Run Unit Tests
        run: mvn test

      - name: Build Backend
        run: mvn clean package -DskipTests

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: backend-jar
          path: backend/target/*.jar

