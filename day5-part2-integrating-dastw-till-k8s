##lets open ci.yml #inside that we have added an dast stage using docker compose which is going to make your container up and running also we are testing the contianer status
name: Enterprise DevSecOps Pipeline

on:
  push:
    branches: [main, skynet]

permissions:
  contents: write
  security-events: write
  actions: read
  id-token: write

env:
  FRONTEND_IMAGE: ${{ secrets.DOCKER_USERNAME }}/frontend
  BACKEND_IMAGE: ${{ secrets.DOCKER_USERNAME }}/backend

jobs:

# -----------------------------
# Build Frontend
# -----------------------------

  frontend-build:
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4

    - uses: actions/setup-node@v4
      with:
        node-version: 20

    - name: Fix npm optional dependency bug
      run: |
        cd frontend
        rm -rf node_modules
        rm -f package-lock.json
        npm install

    - name: Build React
      run: |
        cd frontend
        npm run build
# -----------------------------
# Build Backend
# -----------------------------

  backend-build:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Build Spring Boot
        run: |
          cd backend
          mvn clean package

# -----------------------------
# Docker Build + Scan
# -----------------------------

  docker-build-scan:
    runs-on: ubuntu-latest
    needs: [frontend-build, backend-build]

    steps:
      - uses: actions/checkout@v4

      # Build Images
      - name: Build Frontend Image
        run: docker build -t frontend-image ./frontend

      - name: Build Backend Image
        run: docker build -t backend-image ./backend

      # Install Trivy
      - uses: aquasecurity/setup-trivy@v0.2.0
      # Security Gate Critical Only 
      - name: Scan Frontend Image Fail on Critical
        id: critical_scan
        continue-on-error: true
        run: |
          trivy image --severity CRITICAL --exit-code 1 \
          no-progress frontend-image
          trivy image --severity CRITICAL --exit-code 1 \
          no-progress backend-image
          

      # Scan Images
      - name: Scan Frontend Image(Full Report)
        if: always()
        run: |
          trivy image --severity CRITICAL,HIGH,MEDIUM,LOW \
          --format sarif -o trivy-results.sarif frontend-image

      - name: Scan Backend Image(Full Report)
        if: always()
        run: |
          trivy image --severity CRITICAL,HIGH,MEDIUM,LOW \
          --format sarif -o trivy-results.sarif backend-image

      
      # Docker login
      - name: Docker Login
        run: |
          echo "${{ secrets.DOCKER_PASSWORD }}" | docker login \
          -u ${{ secrets.DOCKER_USERNAME }} --password-stdin

      # Tag images
      - name: Tag Images
        run: |
          docker tag backend-image $BACKEND_IMAGE:${{ github.sha }}
          docker tag frontend-image $FRONTEND_IMAGE:${{ github.sha }}

      # Push images
      - name: Push Images
        run: |
          docker push $BACKEND_IMAGE:${{ github.sha }}
          docker push $FRONTEND_IMAGE:${{ github.sha }}

  dast-test:
    runs-on: ubuntu-latest
    needs: docker-build-scan

    steps:

      - name: Checkout code
        uses: actions/checkout@v4

      # Build containers
      - name: Build containers
        run: docker compose build

      # Start services
      - name: Start application stack
        run: docker compose up -d

      # Wait until backend is ready
      - name: Wait for backend
        run: |
          for i in {1..30}; do
            if curl -s http://localhost:8080 > /dev/null; then
              echo "Backend ready"
              exit 0
            fi
            echo "Waiting for backend..."
            sleep 5
          done
          echo "Backend failed to start"
          docker compose logs backend
          exit 1

      # -----------------------------
      # OWASP ZAP DAST Scan
      # -----------------------------

      - name: Run OWASP ZAP Baseline Scan
        run: |
          chmod -R 777 .
          docker run --user root --network="host" \
          -v $(pwd):/zap/wrk \
          ghcr.io/zaproxy/zaproxy:stable \
          zap-baseline.py \
          -t http://localhost:8080/enquiries \
          -J zap-report.json \
          -r zap-report.html -I

      # -----------------------------
      # Check for Critical Vulnerabilities
      # -----------------------------

      - name: Fail pipeline if CRITICAL vulnerabilities found
        run: |
          if grep -i "High" zap-report.json; then
            echo "CRITICAL/HIGH vulnerabilities found!"
            exit 1
          else
            echo "No critical vulnerabilities found"
          fi

      # Upload report artifact
      - name: Upload ZAP Report
        uses: actions/upload-artifact@v4
        with:
          name: zap-dast-report
          path: |
            zap-report.html
            zap-report.json

#we need to upload the same in github
git add .
git commit -m "added dast state using docker compose"
git push origin skynet
